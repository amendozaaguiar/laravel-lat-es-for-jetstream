{
    "name": "amendozaaguiar/laravel-lat-es-for-jetstream",
    "description": "Archivos de traducción al español latinoamericano para Laravel con Jetstream (auth, pagination, passwords, validation + todas las cadenas de Jetstream).",
    "keywords": [
        "laravel",
        "jetstream",
        "español",
        "traducción",
        "idioma",
        "localización",
        "latin america"
    ],
    "homepage": "https://github.com/amendozaaguiar/laravel-lat-es-for-jetstream",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Anderson Mendoza",
            "email": "amendozaaguiar@outlook.com",
            "homepage": "https://github.com/amendozaaguiar",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Amendozaaguiar\\LaravelLatEsForJetstream\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Amendozaaguiar\\LaravelLatEsForJetstream\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Amendozaaguiar\\LaravelLatEsForJetstream\\LaravelLatEsForJetstreamServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
